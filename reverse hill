public class Main
{
	public static void main(String[] args) {
	int row=5;
       int x = row;
       int y= row;
       int i,j;
       
       for(i=1;i<=row;i++) {
           for(j=1;j<=row*2;j++) {
               if(j==x||j==y)
               System.out.print(x);
               else
               System.out.print(" ");
           }
           x--;
           y++;
           
           System.out.println();
       }
    }
}
